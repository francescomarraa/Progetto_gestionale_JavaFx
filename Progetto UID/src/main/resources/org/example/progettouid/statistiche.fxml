<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<AnchorPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.progettouid.controller.StatisticheController">

    <children>
        <VBox alignment="TOP_CENTER"
              spacing="20"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0"
              styleClass="page-container">

            <padding>
                <Insets top="20" left="20" right="20" bottom="20"/>
            </padding>

            <Label text="Statistiche" styleClass="page-title">
                <font>
                    <Font size="48"/>
                </font>
            </Label>

            <Label text="Seleziona la sezione di cui vuoi visualizzare le statistiche"
                   styleClass="page-subtitle"/>

            <HBox alignment="CENTER" spacing="30">

                <VBox alignment="CENTER"
                      spacing="15"
                      prefWidth="220"
                      prefHeight="140"
                      styleClass="stat-card">

                    <ImageView fitWidth="48"
                               fitHeight="48"
                               preserveRatio="true">
                        <image>
                            <Image url="@../icon/prodotto_stat.png"/>
                        </image>
                    </ImageView>
                    <Label text="Prodotti" styleClass="stat-label"/>

                    <Button text="Visualizza"
                            prefWidth="120"
                            styleClass="primary-button"
                            onAction="#apriStatisticheProdotti">
                        <cursor>
                            <Cursor fx:constant="HAND"/>
                        </cursor>
                    </Button>
                </VBox>

                <VBox alignment="CENTER"
                      spacing="15"
                      prefWidth="220"
                      prefHeight="140"
                      styleClass="stat-card">

                    <ImageView fitWidth="48"
                               fitHeight="48"
                               preserveRatio="true">
                        <image>
                            <Image url="@../icon/cliente_stat.png"/>
                        </image>
                    </ImageView>
                    <Label text="Clienti" styleClass="stat-label"/>

                    <Button text="Visualizza"
                            prefWidth="120"
                            styleClass="primary-button"
                            onAction="#apriStatisticheClienti">
                        <cursor>
                            <Cursor fx:constant="HAND"/>
                        </cursor>
                    </Button>
                </VBox>

                <VBox alignment="CENTER"
                      spacing="15"
                      prefWidth="220"
                      prefHeight="140"
                      styleClass="stat-card">

                    <ImageView fitWidth="48"
                               fitHeight="48"
                               preserveRatio="true">
                        <image>
                            <Image url="@../icon/fornitore_stat.png"/>
                        </image>
                    </ImageView>
                    <Label text="Fornitori" styleClass="stat-label"/>

                    <Button text="Visualizza"
                            prefWidth="120"
                            styleClass="primary-button"
                            onAction="#apriStatisticheFornitori">
                        <cursor>
                            <Cursor fx:constant="HAND"/>
                        </cursor>
                    </Button>
                </VBox>

            </HBox>
        </VBox>
    </children>
</AnchorPane>

