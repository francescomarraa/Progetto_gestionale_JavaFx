<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="627.0" prefWidth="845.0" styleClass="clienti-root" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.progettouid.controller.ListaClientiController">

    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="clienti-toolbar" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <Button fx:id="btnAdd" onAction="#apriDialogCliente" styleClass="btn-primary" text="Aggiungi" />

        <Button fx:id="btnModifica" onAction="#modificaCliente" styleClass="btn-secondary" text="Modifica" />

        <Button fx:id="btnDel" onAction="#eliminaClienti" styleClass="btn-danger" text="Elimina" />

        <Button fx:id="btnScaricaPDF" onAction="#scaricaPdfClienti" styleClass="btn-outline" text="Scarica PDF" />

        <Region HBox.hgrow="ALWAYS" />

        <TextField fx:id="txtCerca" promptText="Cerca cliente..." styleClass="search-field" />

        <Button fx:id="btnCerca" onAction="#cercaCliente" styleClass="btn-primary" text="Cerca" />
    </HBox>

    <TableView fx:id="tabellaClienti" styleClass="clienti-table" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="56">

        <columns>
            <TableColumn fx:id="colonnaNome" prefWidth="211.0" text="Nome" />
            <TableColumn fx:id="colonnaCognome" prefWidth="211.0" text="Cognome" />
            <TableColumn fx:id="colonnaCitta" prefWidth="211.0" text="Città" />
            <TableColumn fx:id="colonnaTelefono" prefWidth="211.0" text="Telefono" />
        </columns>
    </TableView>

</AnchorPane>
