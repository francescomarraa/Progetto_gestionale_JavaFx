<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="400.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.progettouid.controller.PippoBotController">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label alignment="CENTER" maxWidth="1.7976931348623157E308" prefHeight="52.0" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-background-color: #1F2C47; -fx-text-fill: white;" text="Chatta con PippoBot" />
                <TextArea fx:id="chatArea" editable="false" style="-fx-control-inner-background: white;" VBox.vgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="inputArea" onAction="#AvvioPippoBot" onKeyReleased="#onKeyTyped" promptText="Chiedi qualcosa a PippoBot" style="-fx-background-radius: 15; -fx-border-radius: 15; -fx-padding: 10;" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnInvia" onAction="#AvvioPippoBot" style="-fx-background-color: #1f2c47; -fx-background-radius: 15; -fx-text-fill: white; -fx-font-weight: bold;" text="Invia">
                            <cursor>
                                <Cursor fx:constant="HAND" />
                            </cursor>
                            <padding>
                                <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                            </padding>
                        </Button>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
        </VBox>
        <ListView fx:id="listaSuggerimenti" layoutX="10.0" layoutY="485.0" prefHeight="100.0" prefWidth="285.0" style="-fx-border-color: #cccccc;" visible="false" AnchorPane.bottomAnchor="55.0" />
    </children>
</AnchorPane>
