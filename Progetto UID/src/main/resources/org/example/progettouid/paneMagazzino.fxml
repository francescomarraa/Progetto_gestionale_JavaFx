<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="627.0" prefWidth="845.0" styleClass="clienti-root" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.progettouid.controller.ListaProdottiController">

    <HBox spacing="8" styleClass="clienti-toolbar" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <Button fx:id="btnDel" onAction="#eliminaProdotto" styleClass="btn-danger" text="Elimina" />

        <Button fx:id="btnScaricaPDF" onAction="#scaricaPdfProdotti" styleClass="btn-outline" text="Scarica PDF" />

        <TextField fx:id="txtCerca" promptText="Cerca prodotto..." styleClass="search-field" />

        <Button fx:id="btnCerca" onAction="#cercaProdotto" styleClass="btn-primary" text="Cerca" />
    </HBox>

    <TableView fx:id="tabellaProdotti" styleClass="clienti-table" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="51.0">

        <columns>
            <TableColumn fx:id="colonnaCodice" text="Codice" />
            <TableColumn fx:id="colonnaNome" text="Nome" />
            <TableColumn fx:id="colonnaPrezzo" text="Prezzo" />
            <TableColumn fx:id="colonnaQuantita" text="Quantità" />
            <TableColumn fx:id="colonnaCategoria" text="Categoria" />
            <TableColumn fx:id="colonnaFornitore" text="Fornitore" />
            <TableColumn fx:id="colonnaDataCarico" text="Data Carico" />
        </columns>

    </TableView>

</AnchorPane>
